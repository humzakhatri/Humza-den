---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Humza's DEN", description = "Daily Engineering Notebook" } = Astro.props;
const fullTitle = title === "Humza's DEN" ? title : `${title} — Humza's DEN`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="site-title">Humza's DEN</a>
        <span class="site-subtitle">Daily Engineering Notebook</span>
        <nav>
          <a href="/">Home</a>
          <a href="/now">Now</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <span>Humza Khatri · <a href="https://github.com/humzakhatri" target="_blank" rel="noopener">GitHub</a></span>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    background: var(--color-surface);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .site-title {
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .site-subtitle {
    font-size: 0.8rem;
    color: var(--color-text-light);
    font-family: var(--font-mono);
    flex: 1;
  }

  nav {
    display: flex;
    gap: 1.25rem;
  }

  nav a {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  nav a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 1.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    font-size: 0.8rem;
    color: var(--color-text-light);
  }
</style>
